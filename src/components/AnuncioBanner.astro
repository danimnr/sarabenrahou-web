---
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import path from 'path';

const cfgRaw = yaml.load(readFileSync(path.join(process.cwd(), 'src/data/config.yaml'), 'utf8')) as any;
const anuncio = { activo: cfgRaw?.anuncio_activo, texto: cfgRaw?.anuncio_texto, enlace: cfgRaw?.anuncio_enlace };
const mostrar = anuncio.activo && anuncio.texto;
---

{mostrar && (
<div
  id="anuncio-banner"
  role="region"
  aria-label="Anuncio de la biblioteca"
  style="background:var(--color-salvia);color:var(--color-blanco)"
  class="w-full py-4 px-6 text-center font-body text-lg font-medium relative"
>
  <span>{anuncio.texto}</span>
  {anuncio.enlace && (
    <a href={anuncio.enlace} class="underline font-medium ml-2 hover:opacity-80 transition-opacity">
      {anuncio.enlace_texto || 'Ver mas'}
    </a>
  )}
  <button
    id="cerrar-anuncio"
    class="absolute right-3 top-1/2 -translate-y-1/2 opacity-70 hover:opacity-100 transition-opacity"
    aria-label="Cerrar anuncio"
    type="button"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</div>
)}

<script>
  document.getElementById('cerrar-anuncio')?.addEventListener('click', () => {
    const banner = document.getElementById('anuncio-banner');
    if (banner) {
      banner.style.transition = 'max-height 0.4s ease, opacity 0.4s ease, padding 0.4s ease';
      banner.style.maxHeight = banner.offsetHeight + 'px';
      banner.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        banner.style.maxHeight = '0';
        banner.style.opacity = '0';
        banner.style.paddingTop = '0';
        banner.style.paddingBottom = '0';
      });
      setTimeout(() => banner.remove(), 420);
    }
  });
</script>




