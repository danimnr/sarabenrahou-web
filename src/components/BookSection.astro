---
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import path from 'path';

const saraRaw = yaml.load(readFileSync(path.join(process.cwd(), 'src/data/sara.yaml'), 'utf8')) as any;
const libro = saraRaw?.libro ?? {};
---

<section
  id="libro"
  class="py-24 lg:py-32"
  style="background:var(--color-crema)"
  aria-labelledby="libro-titulo"
>
  <div class="container mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Info -->
      <div class="reveal">
        <span class="salvia-line" aria-hidden="true"></span>
        <p class="font-body text-xs font-medium tracking-widest uppercase mb-3" style="color:var(--color-salvia)">
          Mi primera novela
        </p>
        <h2
          id="libro-titulo"
          class="font-display font-semibold mb-6"
          style="font-size:var(--text-display-md);color:var(--color-tierra)"
        >
          {libro.titulo ?? 'La geografía de la memoria'}
        </h2>

        <div class="prose-cottage mb-8">
          {libro.descripcion?.split('\n\n').map((p: string) => (
            <p>{p.trim()}</p>
          ))}
        </div>

        <div class="flex items-center gap-2 mb-8 font-body text-sm" style="color:var(--color-gris)">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true" style="color:var(--color-salvia)">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          Publicado por Diversidad Literaria
        </div>

        <a
          href={libro.enlace ?? 'https://www.diversidadliteraria.com/la-geografia-de-la-memoria'}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          {libro.boton ?? 'Ver en Diversidad Literaria'}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>

      <!-- Portada -->
      <div class="reveal flex justify-center lg:justify-end" style="transition-delay:0.15s">
        <div class="relative w-56 lg:w-72">
          <div
            class="absolute -bottom-4 -right-4 w-full h-full"
            style="background:var(--color-rosa);opacity:0.5"
            aria-hidden="true"
          ></div>
          <img
            src={libro.imagen ?? '/images/libro-geografia.jpg'}
            alt={libro.imagen_alt ?? 'Portada de La geografía de la memoria'}
            width="288"
            height="432"
            class="relative z-10 w-full aspect-[2/3] object-cover"
            style="box-shadow:0 8px 32px rgba(92,74,50,0.15)"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
