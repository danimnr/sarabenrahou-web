---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import BookSection from '../components/BookSection.astro';
import LibrarySection from '../components/LibrarySection.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import path from 'path';

const cfgRaw = yaml.load(readFileSync(path.join(process.cwd(), 'src/data/config.yaml'), 'utf8')) as any;
const seo = { titulo_sitio: cfgRaw?.titulo_sitio ?? 'Sara Benrahou', descripcion: cfgRaw?.descripcion ?? '', imagen_og: cfgRaw?.imagen_og ?? '/images/hero-sara.jpg' };
---

<BaseLayout
  titulo={seo.titulo_sitio ?? 'Sara Benrahou — Escritora y bibliotecaria'}
  descripcion={seo.descripcion ?? ''}
  imagen={seo.imagen_og}
>
  <Header slot="header" />
  <Hero />
  <About />
  <BookSection />
  <LibrarySection />
  <Contact />
  <Footer slot="footer" />
</BaseLayout>

